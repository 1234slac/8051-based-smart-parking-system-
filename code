#include <reg51.h>
sbit entry = P1^0;
sbit exit_sensor = P1^1;
sbit led = P1^7;
void delay()
{
 int i,j;
 for(i=0;i<200;i++)
 for(j=0;j<1000;j++);
}
void open_gate()
{
 P2 = 0x01;
 delay();
 P2 = 0x02;
 delay();
 P2 = 0x04;
 delay();
 P2 = 0x08;
 delay();
}
void close_gate()
{
 P2 = 0x08;
 delay();
 P2 = 0x04;
 delay();
 P2 = 0x02;
 delay();
 P2 = 0x01;
 delay();
}
void main()
{
 entry = 1;
 exit_sensor = 1;
 while(1)
 {
 if(entry == 0)
 {
 open_gate();
 }
 if(exit_sensor == 0)
 {
 close_gate();
 }
 }
